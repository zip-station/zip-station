# Zip Station Environment Configuration
# Copy this file to .env and fill in your values

# --- Version (optional, defaults to latest) ---
# Pin to a specific release: ZIPSTATION_VERSION=1.0.0
ZIPSTATION_VERSION=latest

# --- Firebase (required) ---
# Get these from Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
# Auth domain is auto-derived from project ID if not set
# FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# --- API URL (required for production) ---
# The URL your browser uses to reach the API.
# For local dev: http://localhost:5100
# For production: https://api.yourdomain.com or http://your-server-ip:5100
API_URL=http://localhost:5100

# --- Ports (optional, defaults shown) ---
API_PORT=5100
SPA_PORT=3000
MONGO_PORT=27017

# --- CORS ---
# Comma-separated origins allowed to call the API
# Must include the URL where your dashboard is hosted
ALLOWED_ORIGINS=http://localhost:3000

# --- Encryption ---
# Used to encrypt email passwords at rest. Keep this secret and don't change it after setup.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Firebase Admin SDK (optional) ---
# Required for: deleting user accounts from Firebase on member removal.
# Get from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Copy client_email and private_key from the downloaded JSON file.
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n