# Zip Station Environment Configuration
# Copy this file to .env and fill in your values

# --- Version (optional, defaults to latest) ---
# Pin to a specific release: ZIPSTATION_VERSION=1.0.0
ZIPSTATION_VERSION=latest

# --- Firebase (required) ---
# Get these from Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
# Auth domain is auto-derived from project ID if not set
# FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# --- Ports (optional, defaults shown) ---
API_PORT=5100
SPA_PORT=3000
MONGO_PORT=27017

# --- CORS ---
# Comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# --- Encryption ---
# Used to encrypt email passwords at rest. Keep this secret and don't change it after setup.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
