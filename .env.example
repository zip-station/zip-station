# Zip Station Environment Configuration
# Copy this file to .env and fill in your values

# --- Version (optional, defaults to latest) ---
# Pin to a specific release: ZIPSTATION_VERSION=1.0.0
ZIPSTATION_VERSION=latest

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id

# --- Ports (optional, defaults shown) ---
API_PORT=5100
SPA_PORT=3000
MONGO_PORT=27017

# --- CORS ---
# Comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# --- Encryption ---
# Used to encrypt email passwords at rest. Generate a random string and keep it secret.
# If not set, the API will auto-generate a temporary key (lost on restart = passwords unreadable).
# Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- SPA ---
# The URL the SPA uses to reach the API (used at build time)
VITE_API_URL=http://localhost:5100
